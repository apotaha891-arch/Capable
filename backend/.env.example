# ── Stripe (Workstream B) ───────────────────────────────────────────────────
# Secret API key from https://dashboard.stripe.com/apikeys (sk_test_… or sk_live_…)
STRIPE_SECRET_KEY=
# Webhook signing secret from the webhook endpoint you create (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Frontend origin Stripe Checkout returns to after pay/cancel
FRONTEND_URL=http://localhost:5173
# Optional: override the Price lookup_keys the code resolves (defaults shown).
# Leave unset if you name the Stripe Prices with the default lookup_keys below.
STRIPE_PRICE_INFLUENCE=capable_influence_monthly
STRIPE_PRICE_PRO=capable_pro_monthly
STRIPE_PRICE_DEPLOY_SLOT=capable_deploy_slot_monthly

# If STRIPE_SECRET_KEY is empty, billing routes fall back to simulated mode.
