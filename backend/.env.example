# ── Stripe (Workstream B) ───────────────────────────────────────────────────
# Secret API key from https://dashboard.stripe.com/apikeys (sk_test_… or sk_live_…)
STRIPE_SECRET_KEY=
# Webhook signing secret from the webhook endpoint you create (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Frontend origin Stripe Checkout returns to after pay/cancel
FRONTEND_URL=http://localhost:5173
# Optional: override the Price lookup_keys the code resolves (defaults shown).
# Leave unset if you name the Stripe Prices with the default lookup_keys below.
STRIPE_PRICE_INFLUENCE=capable_influence_monthly
STRIPE_PRICE_PRO=capable_pro_monthly
STRIPE_PRICE_DEPLOY_SLOT=capable_deploy_slot_monthly

# If STRIPE_SECRET_KEY is empty, billing routes fall back to simulated mode.

# ── Production hosting (Railway/Render) ──────────────────────────────────────
# Required: Postgres connection (Supabase).
DATABASE_URL=
# Persistent volume mount for published sites/thumbnails (survives redeploys).
HOSTED_DIR=/data/hosted
# Public base URL of THIS backend (used in published links). e.g. https://api.capable.live
BASE_URL=
# CORS allowlist for the frontend origin(s), comma-separated. e.g. https://capable.live
CORS_ORIGINS=
# Admin emails (comma-separated) auto-promoted to admin.
ADMIN_EMAILS=
# AI keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
JWT_SECRET=
