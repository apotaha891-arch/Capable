# Capable frontend environment variables.
# Copy to `.env` (local) or set in your host's dashboard (e.g. Vercel) for production.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Origin of the Capable backend API. Defaults to http://localhost:5000 when unset.
VITE_API_URL=http://localhost:5000

# Public domain used to build {slug}.domain URLs for published sites.
# Leave unset to fall back to the local renderer below.
# VITE_APP_DOMAIN=capable.app

# Local site renderer origin (used when VITE_APP_DOMAIN is unset).
VITE_RENDERER_URL=http://localhost:3007
